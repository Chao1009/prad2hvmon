#!/bin/sh
# prad2hvmon Python-tool wrapper — generated by CMake.
#
# Resolves <prefix> from the wrapper's own location and sets
# PRAD2HV_DATABASE_DIR / PRAD2HV_RESOURCE_DIR before running the target
# Python script.  Sourcing setup.sh is NOT required.

case "$0" in
    /*)   _self="$0" ;;
    */*)  _self="$PWD/$0" ;;
    *)    _self="$(command -v "$0" 2>/dev/null || printf '%s\n' "$0")" ;;
esac
_wrap_dir="$(cd "$(dirname "$_self")/.." && pwd)"
unset _self

: "${PRAD2HV_DATABASE_DIR:=${_wrap_dir}/share/prad2hvmon/database}"
: "${PRAD2HV_RESOURCE_DIR:=${_wrap_dir}/share/prad2hvmon/resources}"
export PRAD2HV_DATABASE_DIR PRAD2HV_RESOURCE_DIR

exec python3 "${_wrap_dir}/share/prad2hvmon/scripts/@PRAD2HV_WRAPPER_SCRIPT_REL@" "$@"
