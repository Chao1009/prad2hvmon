{
    "deltaV": {
        "table_ok":   2.0,
        "table_warn": 5.0
    },
    "colorRange": {
        "vmon_max": 2100,
        "vset_max": 2100,
        "diff_max": 10.0
    },
    "geoView": {
        "extent": 600
    },
    "intervals": {
        "renderMs": 200
    },
    "polling": {
        "vmon_ms": 200,
        "all_every_n": 10
    },
    "hvMonitor": {
        "fast_buffer_size": 1000,
        "min_sigma_points": 20
    },
    "hvAggregator": {
        "fast_buffer_size": 5000,
        "ring_buffer_size": 100
    },
    "auto_report": {
        "// Master switch.  When true the daemon runs the scheduled-tick": "",
        "// dispatcher; one connected reporter-capable browser is asked to": "",
        "// screenshot every tab and POST the elog XML to /api/elog/post.": "",
        "enabled": true,
        "// Hard server-side guard.  While false, /api/elog/post still": "",
        "// archives the XML + decoded PNG attachments under local_save_dir": "",
        "// but the curl --upload-file step is skipped.  Flip to true only": "",
        "// after a manual review of the saved bodies.": "",
        "post_to_elog": false,
        "// Required.  Each capture is mirrored under": "",
        "// <local_save_dir>/<UTC date>/ as report_<UTC>.xml + the PNGs": "",
        "// decoded out of the XML.  An aggregate summary.json sits at the": "",
        "// top of the dir with one entry per attempt (success or failure).": "",
        "local_save_dir": "/home/clasrun/prad2hv_daq/monitor/reports",
        "// Hard rate limit between two writes inside the same UTC-date": "",
        "// bucket (ms).  Catches near-simultaneous duplicates from a": "",
        "// scheduler retry or a watchdog re-dispatch.": "",
        "min_interval_ms": 600000,
        "// Scheduled-trigger cadence (s).  0 disables the timer; the only": "",
        "// way to fire then is a manual replay via scripts/post_elog.py.": "",
        "// 28800 = once per 8h shift.  Keep at 0 until the saved bodies": "",
        "// look right.": "",
        "scheduled_interval_s": 0,
        "// Logbook target — same cert/key as prad2evviewer's auto-report.": "",
        "// PRADLOG enum tags include Autolog and HV.": "",
        "elog": {
            "url":     "https://logbooks.jlab.org",
            "logbook": "PRADLOG",
            "author":  "clasrun",
            "tags":    ["Autolog", "HV"],
            "cert":    "/home/clasrun/prad2_daq/monitor/keys/elog-cert.pem",
            "key":     "/home/clasrun/prad2_daq/monitor/keys/elog-key.pem"
        }
    }
}
